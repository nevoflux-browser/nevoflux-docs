{
  "name": "nevoflux-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build && node scripts/static-root-redirect.mjs",
    "dev": "next dev --port 3001",
    "start": "serve out",
    "deploy": "bun run build && wrangler pages deploy",
    "preview:cf": "bun run build && wrangler pages dev ./out",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fumadocs/language": "^0.0.1",
    "@orama/orama": "^3.1.18",
    "@orama/tokenizers": "^3.1.18",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.11",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}
