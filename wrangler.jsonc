{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nevoflux-docs",
  // Cloudflare Pages config. The site is a Next.js static export; `bun run build`
  // emits ./out, which Pages serves directly (no server / no OpenNext).
  // Required field for Pages projects:
  "pages_build_output_dir": "./out"
}
