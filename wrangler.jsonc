{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nevoflux-docs",
  "compatibility_date": "2026-06-05",
  // Deploy the Next.js static export (./out) as Cloudflare Workers static assets.
  // No server / no OpenNext. Works with a Workers-scoped API token
  // (`wrangler deploy`), unlike Pages which needs Pages:Edit.
  "assets": {
    "directory": "./out",
    // Per-page HTML (an MPA, not a SPA); serve out/404.html for misses.
    "not_found_handling": "404-page"
  }
}
